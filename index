// ===== NAVEGAÇÃO =====
function show(id){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  var el=document.getElementById(id);
  if(el){el.classList.add('active');el.style.display=(id==='v-login'||id==='v-solicitar')?'flex':'block';}
}
function sec(id,el){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
  var s=document.getElementById('sec-'+id);if(s)s.classList.add('active');
  if(el)el.classList.add('active');
  var m=document.querySelector('.main');if(m)m.scrollTop=0;
}
function tab(g,id,el){
  var p=g+'-';
  document.querySelectorAll('[id^="'+p+'"]').forEach(t=>{if(t.classList.contains('tc'))t.classList.remove('active');});
  var t=document.getElementById(p+id);if(t)t.classList.add('active');
  if(el){el.closest('.tabs').querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');}
}

