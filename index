function doLogin(){
  var email=document.getElementById('email').value.trim().toLowerCase();
  var senha=document.getElementById('senha').value;
  var err=document.getElementById('err');
  var u=USERS[email];
  if(u&&u.pass===senha){
    err.style.display='none';
    document.getElementById('sb-av').textContent=u.ini;
    document.getElementById('sb-name').textContent=u.name;
    document.getElementById('sb-role').textContent=u.role;
    document.getElementById('header-user').textContent=u.name;
    document.getElementById('btn-sair').style.display='block';
    if(u.admin)document.getElementById('adm-nav').style.display='block';
    show('v-dash');
    buildDash();
  } else {
    err.textContent='E-mail ou senha incorretos.';
    err.style.display='block';
  }
}
function logout(){
  document.getElementById('btn-sair').style.display='none';
  document.getElementById('header-user').textContent='';
  document.getElementById('adm-nav').style.display='none';
  document.getElementById('email').value='';
