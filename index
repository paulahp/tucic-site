<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TUCIC — Portal dos Membros</title>
<meta name="robots" content="noindex, nofollow">
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Lato:wght@300;400;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --azul:#13329b;--azul-d:#0e2578;--azul-l:#1a3eb8;
  --ouro:#eece3b;--ouro-d:#c9a820;--ouro-p:#fdf3a0;
  --bg:#080f2e;--borda:rgba(238,206,59,.18);
  --card:rgba(19,50,155,.1);--card-borda:rgba(238,206,59,.13);
  --texto:#e8e8f0;--muted:rgba(180,185,220,.55);
}
html,body{height:100%;font-family:'Lato',sans-serif;background:var(--bg);color:var(--texto);}
.stars{position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:radial-gradient(1px 1px at 8% 12%,rgba(238,206,59,.55) 0%,transparent 100%),radial-gradient(1.5px 1.5px at 48% 7%,rgba(238,206,59,.45) 0%,transparent 100%),radial-gradient(1px 1px at 73% 22%,rgba(238,206,59,.35) 0%,transparent 100%),radial-gradient(1px 1px at 91% 52%,rgba(238,206,59,.4) 0%,transparent 100%),radial-gradient(1.5px 1.5px at 15% 90%,rgba(238,206,59,.45) 0%,transparent 100%),radial-gradient(1px 1px at 58% 85%,rgba(238,206,59,.3) 0%,transparent 100%),radial-gradient(1px 1px at 33% 70%,rgba(238,206,59,.22) 0%,transparent 100%),radial-gradient(1px 1px at 22% 38%,rgba(255,255,255,.12) 0%,transparent 100%);}
.glow{position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(ellipse at 50% 0%,rgba(19,50,155,.4) 0%,transparent 65%);}

/* ===== HEADER ===== */
header{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:13px 22px;border-bottom:1px solid var(--borda);background:rgba(8,15,46,.95);backdrop-filter:blur(8px);}
.logo{display:flex;align-items:center;gap:11px;}
.logo-badge{width:44px;height:44px;border-radius:50%;border:2px solid var(--ouro);background:rgba(238,206,59,.1);display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-size:14px;color:var(--ouro);font-weight:600;flex-shrink:0;}
.logo-name{font-family:'Cinzel',serif;font-size:14px;color:var(--ouro);letter-spacing:2px;}
.logo-sub{font-size:8px;color:rgba(238,206,59,.38);letter-spacing:.4px;margin-top:2px;line-height:1.3;}
#header-user{font-size:11px;color:rgba(238,206,59,.5);}
.btn-sair{padding:6px 14px;border-radius:20px;font-size:11px;cursor:pointer;border:1px solid rgba(238,206,59,.3);color:var(--ouro-d);background:transparent;font-family:'Lato',sans-serif;transition:all .2s;display:none;}
.btn-sair:hover{background:rgba(238,206,59,.08);}

/* ===== VIEWS ===== */
.view{display:none;position:relative;z-index:5;}
.view.active{display:block;}

/* ===== LOGIN ===== */
#v-login{display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 71px);padding:40px 20px;}
.login-box{width:100%;max-width:380px;}
.login-eye{font-size:9px;letter-spacing:3px;color:rgba(238,206,59,.4);text-transform:uppercase;text-align:center;margin-bottom:10px;}
.login-title{font-family:'Cinzel',serif;font-size:26px;color:var(--ouro);text-align:center;letter-spacing:2px;margin-bottom:4px;}
.login-sub{font-family:'Cormorant Garamond',serif;font-size:15px;font-style:italic;color:rgba(200,180,80,.6);text-align:center;margin-bottom:6px;}
.dg{width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--ouro),transparent);margin:0 auto 22px;}
.card{background:var(--card);border:1px solid var(--borda);border-radius:14px;padding:28px;}
.flabel{font-size:9px;letter-spacing:1px;color:rgba(238,206,59,.5);display:block;margin-bottom:5px;text-transform:uppercase;}
.finput{width:100%;padding:10px 14px;background:rgba(19,50,155,.18);border:1px solid rgba(238,206,59,.2);border-radius:8px;color:var(--texto);font-size:13px;font-family:'Lato',sans-serif;outline:none;margin-bottom:14px;transition:border-color .2s;}
.finput:focus{border-color:rgba(238,206,59,.52);}
textarea.finput{resize:vertical;min-height:80px;}
.btn-full{width:100%;padding:12px;background:var(--ouro);color:var(--azul-d);border:none;border-radius:8px;font-family:'Cinzel',serif;font-size:12px;letter-spacing:1px;cursor:pointer;font-weight:700;margin-top:2px;transition:background .2s;}
.btn-full:hover{background:var(--ouro-p);}
.form-switch{text-align:center;margin-top:13px;font-size:12px;color:var(--muted);}
.alink{color:var(--ouro-d);cursor:pointer;text-decoration:underline;}
.hint{text-align:center;margin-top:8px;font-size:9px;color:rgba(140,140,160,.28);}
.err-box{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.25);color:#F87171;border-radius:7px;padding:9px 12px;font-size:12px;margin-bottom:12px;text-align:center;display:none;}
.ok-box{background:rgba(19,50,155,.2);border:1px solid rgba(238,206,59,.22);color:rgba(238,206,59,.8);border-radius:8px;padding:11px;margin-top:12px;font-size:12px;text-align:center;line-height:1.6;}

/* ===== DASHBOARD ===== */
#v-dash{min-height:calc(100vh - 71px);}
.dash-layout{display:flex;min-height:calc(100vh - 71px);}

/* sidebar */
.sidebar{width:210px;flex-shrink:0;border-right:1px solid var(--borda);background:rgba(8,15,46,.5);position:sticky;top:71px;height:calc(100vh - 71px);overflow-y:auto;padding:16px 0;}
.sidebar::-webkit-scrollbar{width:3px;}.sidebar::-webkit-scrollbar-thumb{background:rgba(238,206,59,.15);}
.sb-user{padding:0 13px 14px;border-bottom:1px solid rgba(238,206,59,.1);margin-bottom:12px;}
.sb-av{width:42px;height:42px;border-radius:50%;border:2px solid var(--ouro);background:rgba(238,206,59,.12);display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-size:13px;color:var(--ouro);margin-bottom:7px;}
.sb-name{font-size:12px;font-weight:700;color:var(--texto);}
.sb-role{font-size:9px;color:rgba(238,206,59,.4);letter-spacing:.8px;}
.nav-sec{padding:0 5px;margin-bottom:5px;}
.nav-sec-title{font-size:8px;letter-spacing:1.5px;color:rgba(238,206,59,.24);text-transform:uppercase;padding:0 8px;margin-bottom:3px;}
.ni{display:flex;align-items:center;gap:7px;padding:6px 9px;border-radius:7px;cursor:pointer;font-size:11.5px;color:var(--muted);transition:all .15s;}
.ni:hover{background:rgba(238,206,59,.07);color:rgba(238,206,59,.8);}
.ni.active{background:rgba(19,50,155,.35);color:var(--ouro);border-left:2px solid var(--ouro);padding-left:7px;}
.ni-ic{font-size:12px;width:15px;text-align:center;flex-shrink:0;}
.sb-logout{font-size:10px;color:rgba(170,170,200,.28);cursor:pointer;padding:6px 9px;margin-top:8px;display:block;}
.sb-logout:hover{color:rgba(220,80,80,.55);}

/* main */
.main{flex:1;padding:24px;overflow-y:auto;}
.sec{display:none;}.sec.active{display:block;}
.ph{font-family:'Cinzel',serif;font-size:19px;color:var(--ouro);margin-bottom:3px;}
.ps{font-size:11px;color:rgba(160,165,200,.4);margin-bottom:20px;}

/* componentes */
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:9px;}
.ccard{background:var(--card);border:1px solid var(--card-borda);border-radius:10px;padding:15px;cursor:pointer;transition:all .2s;}
.ccard:hover{border-color:rgba(238,206,59,.42);background:rgba(238,206,59,.05);transform:translateY(-2px);}
.ccard .ci{font-size:22px;margin-bottom:7px;}.ccard .ct{font-size:12px;font-weight:700;color:var(--texto);margin-bottom:3px;}.ccard .cd{font-size:10px;color:var(--muted);line-height:1.4;}

.rc{background:var(--card);border:1px solid var(--card-borda);border-radius:10px;padding:16px;margin-bottom:10px;}
.rt{font-family:'Cormorant Garamond',serif;font-size:16px;color:var(--ouro-d);margin-bottom:4px;}
.rm{font-size:9px;color:rgba(238,206,59,.32);letter-spacing:.9px;text-transform:uppercase;margin-bottom:7px;}
.rb{font-size:12.5px;color:rgba(200,205,230,.68);line-height:1.78;}
.badge{display:inline-block;font-size:9px;padding:2px 8px;border-radius:20px;border:1px solid rgba(238,206,59,.2);color:rgba(238,206,59,.58);margin:0 3px 4px 0;}

.av{border-radius:9px;padding:13px;margin-bottom:9px;}
.av.gold{background:rgba(238,206,59,.07);border:1px solid rgba(238,206,59,.2);color:rgba(238,206,59,.8);}
.av.warn{background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.22);color:#FBBF24;}
.av.green{background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.22);color:#34D399;}
.av.blue{background:rgba(19,50,155,.25);border:1px solid rgba(19,50,155,.5);color:#93C5FD;}
.av .avt{font-size:13px;font-weight:700;margin-bottom:3px;}.av .avb{font-size:12px;line-height:1.7;color:rgba(200,205,230,.7);}
.avtag{display:inline-block;font-size:9px;padding:2px 8px;border-radius:10px;margin-bottom:6px;}

.tabs{display:flex;gap:5px;margin-bottom:15px;flex-wrap:wrap;}
.tab{padding:5px 13px;border-radius:20px;font-size:10.5px;cursor:pointer;border:1px solid rgba(238,206,59,.14);color:var(--muted);background:transparent;transition:all .2s;}
.tab.active{border-color:var(--ouro);color:var(--ouro);background:rgba(238,206,59,.07);}
.tc{display:none;}.tc.active{display:block;}

.li{display:flex;align-items:flex-start;gap:9px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.li:last-child{border-bottom:none;}
.ld{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:5px;border:1px solid rgba(255,255,255,.12);}
.lt{font-size:12.5px;color:rgba(200,205,230,.68);line-height:1.6;}

.gi{border-left:3px solid var(--ouro);padding:10px 14px;margin-bottom:7px;background:var(--card);border-radius:0 8px 8px 0;}
.gn2{font-size:9px;color:rgba(238,206,59,.34);letter-spacing:.8px;margin-bottom:1px;}
.gt{font-size:12.5px;font-weight:700;color:var(--ouro-d);}
.gd{font-size:11.5px;color:rgba(185,190,220,.55);margin-top:3px;line-height:1.6;}

.og{display:grid;grid-template-columns:repeat(auto-fit,minmax(118px,1fr));gap:7px;}
.oc{background:var(--card);border:1px solid var(--card-borda);border-radius:9px;padding:12px;cursor:pointer;transition:all .2s;text-align:center;}
.oc:hover{border-color:rgba(238,206,59,.4);background:rgba(238,206,59,.04);}
.odot{width:11px;height:11px;border-radius:50%;display:inline-block;margin-right:3px;vertical-align:middle;border:1px solid rgba(255,255,255,.14);}
.on{font-family:'Cinzel',serif;font-size:10.5px;color:var(--ouro-d);margin-bottom:2px;}
.os2{font-size:9px;color:var(--muted);font-style:italic;line-height:1.35;}

.ec{background:var(--card);border:1px solid var(--card-borda);border-radius:9px;padding:13px;margin-bottom:8px;}
.en{font-size:13px;font-weight:700;color:var(--ouro-d);margin-bottom:2px;}
.eca{font-size:9px;color:rgba(238,206,59,.32);letter-spacing:.8px;text-transform:uppercase;margin-bottom:5px;}
.ebo{font-size:11.5px;color:var(--muted);line-height:1.65;}

.mb{background:rgba(238,206,59,.07);border:1px solid rgba(238,206,59,.18);border-radius:10px;padding:17px;margin-bottom:10px;display:flex;align-items:center;gap:18px;flex-wrap:wrap;}
.mv{font-family:'Cinzel',serif;font-size:26px;color:var(--ouro);}
.ml{font-size:9.5px;color:rgba(238,206,59,.43);letter-spacing:.7px;}
.sr{display:flex;align-items:flex-start;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.sn{display:inline-flex;align-items:center;justify-content:center;width:21px;height:21px;border-radius:50%;background:rgba(238,206,59,.18);color:var(--ouro);font-size:10px;font-weight:700;margin-right:9px;flex-shrink:0;}
.st{font-size:12px;color:rgba(200,205,230,.66);line-height:1.6;}
.pixb{padding:10px;background:rgba(238,206,59,.05);border-radius:6px;margin-top:9px;font-size:11px;color:rgba(200,205,230,.6);border:1px solid rgba(238,206,59,.1);}

.gc{background:var(--card);border:1px solid var(--card-borda);border-radius:10px;padding:16px;margin-bottom:9px;}
.gtag{display:inline-block;font-size:9px;padding:2px 9px;border-radius:20px;margin-bottom:8px;}

.at{width:100%;border-collapse:collapse;font-size:11.5px;}
.at th{text-align:left;padding:7px 10px;font-size:8px;letter-spacing:.9px;color:rgba(238,206,59,.28);border-bottom:1px solid rgba(238,206,59,.1);}
.at td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.03);color:rgba(200,205,230,.64);}
.sp{color:#FBBF24;}.sa{color:#34D399;}
.ap2{font-size:9px;padding:3px 9px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);color:#34D399;border-radius:20px;cursor:pointer;}
.rj2{font-size:9px;padding:3px 9px;background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.18);color:#F87171;border-radius:20px;cursor:pointer;margin-left:4px;}

@media(max-width:700px){
  .sidebar{width:100%;position:relative;top:0;height:auto;border-right:none;border-bottom:1px solid var(--borda);overflow-x:auto;overflow-y:hidden;padding:8px 0;white-space:nowrap;}
  .sb-user,.nav-sec-title,.sb-logout{display:none;}
  .nav-sec{display:inline-flex;padding:0;}
  .ni{padding:5px 10px;border-radius:20px;}
  .ni.active{border-left:none;padding-left:10px;}
  .dash-layout{flex-direction:column;}
  .main{padding:16px;}
}
</style>
</head>
<body>
<div class="stars"></div>
<div class="glow"></div>

<!-- HEADER -->
<header>
  <div class="logo">
    <div class="logo-badge">T</div>
    <div>
      <div class="logo-name">TUCIC</div>
      <div class="logo-sub">Tenda de Umbanda Cabocla Inaê das Cachoeiras</div>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:10px;">
    <span id="header-user"></span>
    <button class="btn-sair" id="btn-sair" onclick="logout()">Sair</button>
  </div>
</header>

<!-- LOGIN -->
<div id="v-login" class="view active">
  <div class="login-box">
    <div class="login-eye">Portal dos Membros</div>
    <div class="login-title">TUCIC</div>
    <div class="login-sub">Tenda de Umbanda Cabocla Inaê das Cachoeiras</div>
    <div class="dg"></div>
    <div class="card">
      <div class="err-box" id="err"></div>
      <label class="flabel">E-mail</label>
      <input class="finput" type="email" id="email" placeholder="seu@email.com" autocomplete="email">
      <label class="flabel">Senha</label>
      <input class="finput" type="password" id="senha" placeholder="••••••••" autocomplete="current-password">
      <button class="btn-full" onclick="doLogin()">Acessar o Portal</button>
      <div class="form-switch">Não tem acesso? <span class="alink" onclick="show('v-solicitar')">Solicite aqui</span></div>
      <div class="hint">admin@tucic.com / tucic2024 &nbsp;·&nbsp; membro@tucic.com / tucic2024</div>
    </div>
  </div>
</div>

<!-- SOLICITAR -->
<div id="v-solicitar" class="view" style="display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 71px);padding:40px 20px;">
  <div style="width:100%;max-width:380px;">
    <div class="login-eye">Solicitar Acesso</div>
    <div class="login-title">TUCIC</div>
    <div class="dg"></div>
    <div class="card" id="sol-form">
      <label class="flabel">Nome completo</label>
      <input class="finput" type="text" placeholder="Como você é conhecido(a) no terreiro">
      <label class="flabel">E-mail</label>
      <input class="finput" type="email" placeholder="seu@email.com">
      <label class="flabel">Relação com o TUCIC</label>
      <input class="finput" type="text" placeholder="Ex: filho(a) de santo, médium em desenvolvimento...">
      <label class="flabel">Mensagem (opcional)</label>
      <textarea class="finput" placeholder="Sua caminhada espiritual..."></textarea>
      <button class="btn-full" onclick="document.getElementById('sol-form').style.display='none';document.getElementById('sol-ok').style.display='block';">Enviar Solicitação</button>
      <div class="form-switch"><span class="alink" onclick="show('v-login')">← Voltar ao login</span></div>
    </div>
    <div id="sol-ok" style="display:none;" class="card" style="text-align:center;">
      <div style="font-size:36px;text-align:center;margin-bottom:12px;">🙏</div>
      <div style="font-family:'Cinzel',serif;font-size:16px;color:var(--ouro);text-align:center;margin-bottom:7px;">Solicitação Enviada!</div>
      <div style="font-size:12px;color:var(--muted);text-align:center;">Você será notificado por e-mail quando aprovado(a) pela Mãe Rosi de Oxum.</div>
      <div class="ok-box">Axé! Aguarde com fé e paciência. 🌿</div>
      <button class="btn-full" style="margin-top:14px;" onclick="show('v-login')">Voltar ao login</button>
    </div>
  </div>
</div>

<!-- DASHBOARD -->
<div id="v-dash" class="view">
<div class="dash-layout">

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="sb-user">
      <div class="sb-av" id="sb-av">M</div>
      <div class="sb-name" id="sb-name">Membro</div>
      <div class="sb-role" id="sb-role">MEMBRO</div>
    </div>
    <div class="nav-sec">
      <div class="nav-sec-title">Principal</div>
      <div class="ni active" onclick="sec('inicio',this)"><span class="ni-ic">🏠</span>Início</div>
      <div class="ni" onclick="sec('avisos',this)"><span class="ni-ic">📢</span>Avisos</div>
      <div class="ni" onclick="sec('calendario',this)"><span class="ni-ic">🗓️</span>Calendário</div>
    </div>
    <div class="nav-sec">
      <div class="nav-sec-title">Manual do Médium</div>
      <div class="ni" onclick="sec('bemestar',this)"><span class="ni-ic">📋</span>Bem-vindo(a)</div>
      <div class="ni" onclick="sec('preceitos',this)"><span class="ni-ic">🕊️</span>Preceitos</div>
      <div class="ni" onclick="sec('mensalidade',this)"><span class="ni-ic">💰</span>Mensalidade</div>
      <div class="ni" onclick="sec('vela',this)"><span class="ni-ic">🕯️</span>Consagrar Vela</div>
      <div class="ni" onclick="sec('guias',this)"><span class="ni-ic">📿</span>Guias</div>
      <div class="ni" onclick="sec('obrigacoes',this)"><span class="ni-ic">📌</span>Obrigações</div>
      <div class="ni" onclick="sec('hierarquia',this)"><span class="ni-ic">🏛️</span>Hierarquia</div>
      <div class="ni" onclick="sec('postura',this)"><span class="ni-ic">🤝</span>Postura</div>
      <div class="ni" onclick="sec('cursos',this)"><span class="ni-ic">🎓</span>Cursos</div>
    </div>
    <div class="nav-sec">
      <div class="nav-sec-title">Saberes</div>
      <div class="ni" onclick="sec('banhos',this)"><span class="ni-ic">🌿</span>Banhos de Ervas</div>
      <div class="ni" onclick="sec('defumacao',this)"><span class="ni-ic">🌫️</span>Defumação</div>
      <div class="ni" onclick="sec('batefolhas',this)"><span class="ni-ic">🍃</span>Bate-Folhas</div>
      <div class="ni" onclick="sec('chas',this)"><span class="ni-ic">🫖</span>Chás e Pós</div>
    </div>
    <div class="nav-sec">
      <div class="nav-sec-title">Tradição</div>
      <div class="ni" onclick="sec('orixas',this)"><span class="ni-ic">✨</span>Orixás</div>
      <div class="ni" onclick="sec('giras',this)"><span class="ni-ic">🌀</span>Giras</div>
      <div class="ni" onclick="sec('linhas',this)"><span class="ni-ic">〰️</span>Linhas</div>
      <div class="ni" onclick="sec('historia',this)"><span class="ni-ic">📖</span>História</div>
    </div>
    <div class="nav-sec" id="adm-nav" style="display:none;">
      <div class="nav-sec-title">Administração</div>
      <div class="ni" onclick="sec('admin',this)"><span class="ni-ic">👤</span>Membros</div>
    </div>
    <span class="sb-logout" onclick="logout()">← Sair do portal</span>
  </nav>

  <!-- MAIN -->
  <main class="main">

    <!-- INÍCIO -->
    <div id="sec-inicio" class="sec active">
      <div class="ph">Bem-vindo(a) ao Portal</div>
      <div class="ps">Saravá! Axé, força e luz na sua caminhada. 🌿</div>
